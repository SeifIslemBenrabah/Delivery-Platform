# ─── Database ────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your_mongo_password
REDIS_PASSWORD=your_redis_password

# ─── Microservice DB URLs ─────────────────────────────────────────────────────
MS_USER_DATABASE_URL=mysql://root:your_mysql_root_password@mysql:3306/dp_users
MS_COMMANDE_DB_URL=jdbc:mysql://mysql:3306/dp_commandes?useSSL=false&serverTimezone=UTC
MS_OPTIMISATION_DB_URL=mysql://root:your_mysql_root_password@mysql:3306/dp_optimisation
MS_PAIEMENT_DATABASE_URL=mysql://root:your_mysql_root_password@mysql:3306/dp_paiement
MS_SUIVI_MONGO_URI=mongodb://admin:your_mongo_password@mongodb:27017/dp_suivi?authSource=admin

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_at_least_64_chars_long
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Payment (Chargily) ───────────────────────────────────────────────────────
CHARGILY_API_KEY=your_chargily_api_key
CHARGILY_SECRET_KEY=your_chargily_secret_key
CHARGILY_WEBHOOK_URL=https://yourdomain.com/api/payment/webhook
APP_BASE_URL=http://localhost

# ─── Maps ────────────────────────────────────────────────────────────────────
GRAPHHOPPER_URL=https://graphhopper.com/api/1
GRAPHHOPPER_API_KEY=your_graphhopper_api_key

# ─── Frontend (Web) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws